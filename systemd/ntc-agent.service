[Unit]
Description=NTC Agent decision service
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
WorkingDirectory=/root/NTC-Agent
Environment=PYTHONUNBUFFERED=1
Environment=NTC_AGENT_HOST=127.0.0.1
Environment=NTC_AGENT_PORT=1981
Environment=NTC_AGENT_TITLE_MAX_WORDS=7
Environment=NTC_AGENT_LLM_BASE_URL=http://100.66.210.59:8768
Environment=NTC_AGENT_LLM_MODEL=mlx-community/Qwen3-8B-4bit
ExecStart=/usr/bin/python3 /root/NTC-Agent/ntc_agent_app.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
